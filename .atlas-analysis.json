  "keyFeatures": [
    "Service-to-service invocation with built-in mTLS security",
    "Pub/Sub messaging with pluggable providers and at-least-once delivery",
    "State management with pluggable datastores and consistency models",
    "Workflow orchestration for durable, long-running processes",
    "Virtual actors for stateful, single-threaded execution",
    "Input/output bindings for event-driven integrations",
    "Secrets management integrated with cloud key vaults",
    "Distributed lock and configuration APIs",
    "Cryptography APIs for encryption and digital signatures",
    "Built-in observability with OpenTelemetry tracing and metrics",
    "Resiliency policies: circuit breakers, retries, timeouts",
    "Sidecar model — language and framework agnostic",
    "Native Kubernetes support via Operator and CRDs",
    "Self-hosted mode for local development",
    "Jobs/scheduler API for cron and one-time jobs"
  ],
  "publicApiSurface": [
    "POST /v1.0/invoke/{appId}/method/{method-name}",
    "GET/POST/PUT/DELETE /v1.0/state/{storeName}/{key}",
    "POST /v1.0/publish/{pubsubname}/{topic}",
    "GET /v1.0-alpha1/workflows/{workflowComponent}/{instanceID}",
    "POST /v1.0-alpha1/workflows/{workflowComponent}/{workflowName}/start",
    "POST /v1.0/actors/{actorType}/{actorId}/method/{method}",
    "GET/POST /v1.0/secrets/{secretStoreName}/{key}",
    "POST /v1.0/bindings/{name}",
    "POST /v1.0-alpha1/lock/{storeName}",
    "POST /v1.0-alpha1/crypto/{CryptoComponentName}/encrypt",
    "GET /v1.0/configuration/{storeName}",
    "GET /v1.0/metadata",
    "POST /v1.0-alpha1/jobs/{name}",
    "POST /v1.0-alpha1/conversation/{llm-name}/converse",
    "dapr.proto.runtime.v1.Dapr gRPC service"
  ]
